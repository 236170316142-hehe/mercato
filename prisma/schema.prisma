generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  projects  Project[]
  templates ExportTemplate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── Core ─────────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  marketplace String   // amazon | bestbuy | walmart | temu | mathis | sears
  status      String   @default("uploaded") // uploaded | verifying | verified | categorizing | categorized | exporting | done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

model Product {
  id          String  @id @default(cuid())
  projectId   String
  vendorSku   String?
  upc         String?
  asin        String?
  name        String
  brand       String?
  description String?
  price       Float?
  imageUrl    String?
  vendorData  Json?   // full raw vendor row

  // Verification
  verifyStatus String?   // ok | warning | mismatch | not_found | pending
  liveData     Json?     // raw marketplace response
  verifyFields Json?     // field-by-field comparison array
  verifiedAt   DateTime?

  // Categorization
  marketplaceCategory String?
  categoryPath        String?
  categoryConfidence  Float?
  categorizedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([upc])
  @@index([asin])
}

// ── Keepa cache (Amazon only) ─────────────────────────────────────────────────
// Keepa bills per product token, so every lookup we can answer locally is money
// saved. Two tables because the two halves age very differently: a barcode→ASIN
// binding is effectively permanent, while product data goes stale.

/// Barcode → ASIN resolution, keyed by canonical GTIN-14 (see lib/barcode.ts).
///
/// This is the expensive half. A code that misses the batch lookup currently
/// costs a rescue call plus up to ~10 keyword-search calls, so remembering the
/// answer — including "there is no answer" — is where most of the savings are.
model KeepaCodeLookup {
  code      String // canonical GTIN-14
  domain    Int // Keepa domain id (1 = amazon.com)
  asins     String[] // empty = confirmed absent from Amazon (negative cache)
  /// How the mapping was resolved. Keyword matches are fuzzy guesses rather
  /// than authoritative barcode hits, so they expire sooner.
  source    String // batch | rescue | keyword
  fetchedAt DateTime @default(now())

  @@id([code, domain])
  @@index([fetchedAt])
}

/// ASIN → raw Keepa product payload.
///
/// Stores the raw KeepaProduct, not the normalized shape: normalizeProduct() is
/// a pure function, so keeping it outside the cache boundary means normalization
/// logic can change without invalidating stored rows.
model KeepaProductCache {
  asin      String
  domain    Int
  raw       Json // full KeepaProduct as returned by the API
  /// Split out because it ages differently from the rest of the payload: price
  /// feeds candidate scoring and export files, so a stale value picks the wrong
  /// ASIN. Identity fields (title/brand/dimensions) effectively never change.
  priceAt   DateTime @default(now())
  fetchedAt DateTime @default(now())

  @@id([asin, domain])
  @@index([fetchedAt])
}

// ── Templates ─────────────────────────────────────────────────────────────────

model ExportTemplate {
  id          String   @id @default(cuid())
  userId      String?  // null = global (admin-created); set = user-private
  name        String
  marketplace String
  category    String?
  fileFormat  String   @default("xlsx") // xlsx | csv
  columns     Json     // [{ key, label, required }]
  fileData    Bytes?   // raw uploaded template file — used as base workbook on export
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
